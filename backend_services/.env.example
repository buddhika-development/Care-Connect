# ==================== DATABASE ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=care_connect

# ==================== AI SERVICES ====================
# Google API Keys
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# Mistral API Keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ==================== API GATEWAY ====================
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ==================== SUPABASE ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==================== SECRETS ====================
GATEWAY_SECRET=your_gateway_secret_here
INTERNAL_SECRET=your_internal_secret_here

# ==================== NOTIFICATION SERVICE ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ==================== PATIENT MANAGEMENT SERVICE ====================
# PayHere
PAYHERE_MERCHANT_ID=your_payhere_merchant_id_here
PAYHERE_MERCHANT_SECRET=your_payhere_merchant_secret_here
PAYHERE_BASE_URL=https://sandbox.payhere.lk/pay/checkout
