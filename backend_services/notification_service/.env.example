# Server
PORT=3006

# API Gateway
GATEWAY_SECRET=your_gateway_secret_here

# ── Email (SMTP / Nodemailer) ──────────────────────────────────────────────────
# For Gmail: enable "App Passwords" and use smtp.gmail.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=Care Connect

# ── SMS (Twilio) ───────────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Choose ONE of the three sender options below (priority: Messaging Service > Alpha > Phone):

# OPTION 1 (Recommended) — Twilio Messaging Service SID (handles country routing automatically)
# Create one at: https://console.twilio.com/us1/develop/sms/services
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION 2 — Alphanumeric Sender ID (e.g. "CareConnect", max 11 chars, no spaces)
# Supported in Sri Lanka (+94) and most countries. NOT supported in USA/Canada.
# TWILIO_ALPHANUMERIC_SENDER=CareConnect

# OPTION 3 — Twilio-purchased phone number in E.164 format
# Must be a number you bought from Twilio console, NOT your personal number.
# TWILIO_PHONE_NUMBER=+12345678901
